# ===========================================
# Red Alert WhatsApp Bot — Configuration
# ===========================================

# WhatsApp group ID for alerts (required)
# Run `npm run setup` to find it
WHATSAPP_GROUP_ID=

# WhatsApp group ID for maintenance/status messages (optional)
# Create a separate group for bot operators to monitor health
MAINTENANCE_GROUP_ID=

# Pikud HaOref polling interval (ms)
PIKUD_HAOREF_POLL_INTERVAL_MS=3000

# Filter by city names (comma-separated, Hebrew)
# Leave empty to receive ALL alerts nationwide
# Example: FILTER_CITIES=נוה איתן,מעוז חיים
FILTER_CITIES=

# Send "event ended" messages? (true/false)
SEND_EVENT_ENDED=true

# Deduplication window (ms) — alerts within this window are suppressed
DEDUP_WINDOW_MS=60000

# How often to send status to maintenance group (ms, default 30 min)
MAINTENANCE_STATUS_INTERVAL_MS=1800000

# Max age of queued messages before they are dropped (ms, default 3 min)
# Messages older than this are stale — if alert didn't arrive in 3 minutes, it's too late.
MAX_QUEUE_AGE_MS=180000

# Logging level: debug, info, warn, error
LOG_LEVEL=info
