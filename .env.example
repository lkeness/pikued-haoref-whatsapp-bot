# ===========================================
# Red Alert WhatsApp Bot — Configuration
# ===========================================

# WhatsApp group ID (required)
# Run `npm run setup` to find it
WHATSAPP_GROUP_ID=

# Pikud HaOref polling interval (ms)
PIKUD_HAOREF_POLL_INTERVAL_MS=3000

# Filter by city names (comma-separated, Hebrew)
# Leave empty to receive ALL alerts nationwide
# Example: # FILTER_CITIES=נוה איתן,מעוז חיים
FILTER_CITIES=

# Send "event ended" messages? (true/false)
SEND_EVENT_ENDED=true

# Deduplication window (ms) — alerts within this window are suppressed
DEDUP_WINDOW_MS=60000

# Logging level: debug, info, warn, error
LOG_LEVEL=info
